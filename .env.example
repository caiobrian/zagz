# ── AI ──────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# AI_PROVIDER: gemini (default) | anthropic | openai
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── WhatsApp ─────────────────────────────────
USER_NAME=
# JID autorizado a gerenciar cron jobs (ex: 5511999999999). Deixe vazio para desabilitar a restrição.
AUTHORIZED_JID=

# ── Channels ─────────────────────────────────
# Canais ativos separados por vírgula: whatsapp, telegram (default: whatsapp)
CHANNELS=whatsapp
TELEGRAM_BOT_TOKEN=

# ── Database ─────────────────────────────────
DATABASE_FILE=database.db

# ── Tools ────────────────────────────────────
TAVILY_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── Self modification ─────────────────────────
ALLOW_SELF_MODIFICATION=false

# ── Webhooks ─────────────────────────────────
# Deixe vazio para desabilitar o servidor de webhooks
WEBHOOK_PORT=
WEBHOOK_SECRET=

# ── Cartão de crédito (pagamentos online) ─────
# ATENÇÃO: nunca commite este arquivo com dados reais
CARD_NUMBER=
CARD_HOLDER_NAME=
CARD_EXPIRY_MONTH=
CARD_EXPIRY_YEAR=
CARD_CVV=

# Dados de cobrança (necessários em alguns sites)
CARD_BILLING_CPF=
CARD_BILLING_ZIP=
CARD_BILLING_ADDRESS=
CARD_BILLING_CITY=
CARD_BILLING_STATE=

TZ=America/Sao_Paulo
